{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sillyTavern-launcher-gui",
  "version": "0.1.0",
  "identifier": "com.sillyTavern-launcher-gui.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "酒馆启动器",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "maxWidth": 1200,
        "minHeight": 800,
        "maxHeight": 800,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"]
      },
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    }
  }
}
