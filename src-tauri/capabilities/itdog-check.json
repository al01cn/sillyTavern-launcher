{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "itdog-check",
  "description": "Capability for itdog hidden check windows (network availability detection)",
  "platforms": [
    "macOS",
    "windows",
    "linux"
  ],
  "windows": [
    "itdog-check-v4",
    "itdog-check-v6"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten"
  ]
}
