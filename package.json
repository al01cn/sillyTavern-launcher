{
  "name": "sillytavern-launcher-gui",
  "description": "SillyTavern Launcher GUI 是一个专为 SillyTavern 设计的跨平台桌面客户端，基于 Tauri v2 + Vue 3 + Rust 构建。它提供了直观、现代的图形界面，让用户无需命令行即可完整管理 SillyTavern 的安装、启动、配置和扩展。",
  "descriptionEn": "SillyTavern Launcher GUI is a cross-platform desktop client built with Tauri v2 + Vue 3 + Rust, designed specifically for SillyTavern. It provides a modern graphical interface to fully manage SillyTavern without using the command line.",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "homepage": "https://st.al01.cn/",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "sync-version": "node scripts/sync-version.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "bun run sync-version && tauri build",
    "cargo:clean": "cd src-tauri && cargo clean",
    "cargo:check": "cd src-tauri && cargo check",
    "cargo:build": "cd src-tauri && cargo build",
    "allcheck": "bun run typecheck && bun run cargo:check"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "~2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "~2",
    "@tauri-apps/plugin-updater": "~2",
    "express": "^5.2.1",
    "fflate": "^0.8.2",
    "gstinfo": "^0.0.3",
    "lucide-vue-next": "^0.577.0",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@iconify-json/material-icon-theme": "^1.2.56",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.74",
    "@iconify/vue": "^5.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
